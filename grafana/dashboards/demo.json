{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": false,
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["thanos", "demo"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Thanos Unification Demo",
  "uid": "thanos-demo",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Apps visible in one view",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": { "unit": "none", "color": { "mode": "fixed", "fixedColor": "purple" } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "count(demo_app)",
          "instant": true,
          "legendFormat": "apps"
        }
      ]
    },
    {
      "id": 2,
      "type": "table",
      "title": "Which apps are reporting (demo_app)",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 6, "w": 18, "x": 6, "y": 0 },
      "options": { "showHeader": true },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "transformations": [
        {
          "id": "labelsToFields",
          "options": { "mode": "columns" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Value": true, "__name__": true, "job": false, "instance": false },
            "renameByName": {}
          }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "demo_app",
          "instant": true,
          "format": "table"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Request rate by language  (all 4 apps, one query)",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "sum by (language) (rate(demo_requests_total[1m]))",
          "legendFormat": "{{language}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Shared target  (toggle 'Deduplication' in Thanos to see 1 vs 2 series)",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "rate(shared_heartbeat_total[1m])",
          "legendFormat": "shared heartbeat"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Go goroutines  (only visible via the unified view)",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "go_goroutines{job=\"go\"}",
          "legendFormat": "goroutines"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "JVM heap used  (Spring Boot, only visible via the unified view)",
      "datasource": { "type": "prometheus", "uid": "thanos" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "thanos" },
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\"})",
          "legendFormat": "heap used"
        }
      ]
    }
  ]
}
